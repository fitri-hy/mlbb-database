  "main": "app.js",
  "scripts": {
    "start": "npm run build:css && node app.js",
    "dev": "concurrently \"npm run watch:css\" \"nodemon app.js\"",
    "build:css": "postcss public/assets/css/tailwind.css -o public/assets/css/styles.css",
    "watch:css": "postcss public/assets/css/tailwind.css -o public/assets/css/styles.css --watch",
    "generate": "node generate-data.js"
  },
