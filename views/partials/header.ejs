<header class="fixed top-0 z-50 w-full bg-black/40 backdrop-blur-md shadow-md shadow-black/20">
    <div class="flex items-center justify-between p-4">
        <a href="/" class="flex items-center gap-2">
            <img class="h-9 w-auto object-contain" src="/assets/images/logo.png" alt="logo" />
        </a>

        <button id="menuBtn" class="text-white md:hidden">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M4 6h16M4 12h16M4 18h16" />
            </svg>
        </button>

        <nav class="hidden md:flex items-center gap-10 text-white">
            <a href="/" class="text-[#ffbd00] text-xs font-bold tracking-[0.3em] uppercase transition-all duration-300 hover:drop-shadow-[0_0_6px_#ffbd00]">
                Home
            </a>

            <div class="group relative">
                <div class="flex items-center gap-1 cursor-pointer py-2">
                    <span class="text-xs font-bold tracking-[0.3em] uppercase group-hover:text-[#ffbd00] transition-all duration-300">
                        Heroes
                    </span>
                    <svg class="w-3 h-3 transition-transform duration-300 group-hover:rotate-180 group-hover:text-[#ffbd00]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </div>
                <div class="absolute top-full right-0 pt-2 w-48">
                    <div class="bg-black/80 backdrop-blur-lg rounded-lg opacity-0 invisible translate-y-2 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 transition-all duration-300 shadow-xl">
                        <a href="/heroes" class="block px-4 py-2 text-xs hover:bg-[#ffbd00] hover:text-black transition">Hero List</a>
                        <a href="/tiers" class="block px-4 py-2 text-xs hover:bg-[#ffbd00] hover:text-black transition">Tier List</a>
                        <a href="/counter" class="block px-4 py-2 text-xs hover:bg-[#ffbd00] hover:text-black transition">Hero Counters</a>
                    </div>
                </div>
            </div>

            <div class="group relative">
                <div class="flex items-center gap-1 cursor-pointer py-2">
                    <span class="text-xs font-bold tracking-[0.3em] uppercase group-hover:text-[#ffbd00] transition-all duration-300">
                        Library
                    </span>
                    <svg class="w-3 h-3 transition-transform duration-300 group-hover:rotate-180 group-hover:text-[#ffbd00]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </div>
                <div class="absolute top-full right-0 pt-2 w-48">
                    <div class="bg-black/80 backdrop-blur-lg rounded-lg opacity-0 invisible translate-y-2 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 transition-all duration-300 shadow-xl">
                        <a href="/emblem" class="block px-4 py-2 text-xs hover:bg-[#ffbd00] hover:text-black transition">Emblems</a>
                        <a href="/ability" class="block px-4 py-2 text-xs hover:bg-[#ffbd00] hover:text-black transition">Abilities</a>
                        <a href="/items" class="block px-4 py-2 text-xs hover:bg-[#ffbd00] hover:text-black transition">Items</a>
                    </div>
                </div>
            </div>

            <div class="group relative">
                <div class="flex items-center gap-1 cursor-pointer py-2">
                    <span class="text-xs font-bold tracking-[0.3em] uppercase group-hover:text-[#ffbd00] transition-all duration-300">
                        Stats
                    </span>
                    <svg class="w-3 h-3 transition-transform duration-300 group-hover:rotate-180 group-hover:text-[#ffbd00]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </div>
                <div class="absolute top-full right-0 pt-2 w-48">
                    <div class="bg-black/80 backdrop-blur-lg rounded-lg opacity-0 invisible translate-y-2 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 transition-all duration-300 shadow-xl">
                        <a href="/stats" class="block px-4 py-2 text-xs hover:bg-[#ffbd00] hover:text-black transition">Win Rates</a>
                        <a href="/tournament" class="block px-4 py-2 text-xs hover:bg-[#ffbd00] hover:text-black transition">Tournaments</a>
                    </div>
                </div>
            </div>
        </nav>
    </div>

    <div id="mobileMenu" class="hidden flex-col bg-black/90 text-white px-4 pb-4 space-y-2 md:hidden transition-all duration-300">
        <a href="/" class="block py-2 text-xs font-bold uppercase text-[#ffbd00]">Home</a>

        <div>
            <button class="w-full flex justify-between items-center py-2 text-xs font-bold uppercase" onclick="toggleDropdown('heroesMenu', this)">
                Heroes
                <svg class="w-3 h-3 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
            </button>
            <div id="heroesMenu" class="hidden pl-4 space-y-1">
                <a href="/heroes" class="block py-1 text-xs">Hero List</a>
                <a href="/tiers" class="block py-1 text-xs">Tier List</a>
                <a href="/counter" class="block py-1 text-xs">Hero Counters</a>
            </div>
        </div>

        <div>
            <button class="w-full flex justify-between items-center py-2 text-xs font-bold uppercase" onclick="toggleDropdown('libraryMenu', this)">
                Library
                <svg class="w-3 h-3 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
            </button>
            <div id="libraryMenu" class="hidden pl-4 space-y-1">
                <a href="/emblem" class="block py-1 text-xs">Emblems</a>
                <a href="/ability" class="block py-1 text-xs">Abilities</a>
                <a href="/items" class="block py-1 text-xs">Items</a>
            </div>
        </div>

        <div>
            <button class="w-full flex justify-between items-center py-2 text-xs font-bold uppercase" onclick="toggleDropdown('statsMenu', this)">
                Stats
                <svg class="w-3 h-3 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
            </button>
            <div id="statsMenu" class="hidden pl-4 space-y-1">
                <a href="/stats" class="block py-1 text-xs">Win Rates</a>
                <a href="/tournament" class="block py-1 text-xs">Tournaments</a>
            </div>
        </div>
    </div>
</header>