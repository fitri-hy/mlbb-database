<article class="h-full flex-1">
	<section class="relative">
		<img class="fixed top-0 left-0 w-full h-full object-cover opacity-80 -z-10 trans-bottom" src="/assets/images/banner.webp" alt="banner" />
		<div class="container px-4 mx-auto grid grid-cols-1	lg:grid-cols-3 gap-9 pt-20 lg:pt-30 pb-16">
			<div class="lg:col-span-2 relative group">	
				<div class="relative bg-black rounded-xl overflow-hidden border border-white/10">
					<div class="absolute inset-0 bg-gradient-to-t from-black/90 via-transparent to-transparent z-10"></div>
					<div class="absolute top-0 left-0 w-12 h-12 border-t-2 border-l-2 border-[#ffbd00] z-20 rounded-tl-xl"></div>
					<div class="absolute bottom-0 right-0 w-12 h-12 border-b-2 border-r-2 border-[#ffbd00] z-20 rounded-br-xl"></div>
					<img class="aspect-video object-cover w-full h-full max-h-[600px] lg:max-h-[500px] transform group-hover:scale-105 transition-transform duration-700" 
						 src="/assets/images/banner/1.jpg" alt="banner-1" />
					<div class="absolute p-4 lg:p-0 lef-0 bottom-0 lg:bottom-8 lg:left-8 z-30 max-w-2xl">
						<span class="bg-[#ffbd00] text-black text-[10px] font-black px-4 py-1 uppercase tracking-[0.3em] skew-x-[-15deg] inline-block shadow-[4px_4px_0px_rgba(0,0,0,0.3)]">
							New
						</span>

						<h2 class="lg:text-4xl font-black italic uppercase tracking-tighter mt-3 drop-shadow-[0_4px_12px_rgba(0,0,0,0.8)] leading-[0.9] text-white">
							The Unbreakable <span class="text-[#ffbd00]">Fortress</span> Standing Against The Chaos
						</h2>

						<p class="mt-2 lg:mt-4 text-gray-300 text-xs lg:text-sm font-medium leading-relaxed max-w-sm drop-shadow-md italic border-l-2 border-[#ffbd00] pl-4">
							Dominate the frontline with Obsidio's impenetrable shield and crush any resistance.
						</p>
					</div>
				</div>
			</div>
			<div class="relative text-white space-y-4">
				<div class="space-y-4">
					<div class="flex items-center mb-6 border-b border-white/20 gap-2 pb-2">
						<div class="h-4 w-4 bg-[#ffbd00] rotate-40"></div>
						<h3 class="text-xl font-black italic uppercase tracking-tighter text-white">
							Final <span class="text-[#ffbd00]">Tournaments</span>
						</h3>
					</div>

					<div class="grid gap-3">
						<% if (tournaments && tournaments.length > 0) { %>
							<% tournaments.slice(0, 4).forEach(tournament => { %>
								<a href="<%= tournament.link %>" target="_blank"
								   class="group relative flex items-center justify-between p-4 gap-4 bg-white/5 backdrop-blur-xs border border-white/5 rounded-lg hover:border-[#ffbd00]/50 hover:bg-white/10 transition-all duration-300 overflow-hidden">
									<div class="absolute inset-y-0 left-0 w-1 bg-[#ffbd00] transform -translate-x-full group-hover:translate-x-0 transition-transform"></div>
									
									<div class="flex flex-col">
										<span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">
											<%= tournament.date %>
										</span>
										<span class="overflow-hidden line-clamp-1 text-sm font-black text-white group-hover:text-[#ffbd00] transition-colors uppercase">
											<%= tournament.name %>
										</span>
									</div>

									<div class="flex items-center gap-3">
										<div class="text-[10px] font-bold py-1 px-2 bg-white/10 rounded text-gray-300 uppercase italic">
											Major
										</div>
										<svg class="w-4 h-4 text-gray-500 group-hover:text-[#ffbd00] transform group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"></path>
										</svg>
									</div>
								</a>
							<% }) %>
						<% } else { %>
							<div class="text-center py-4 text-gray-500 text-[10px] font-mono italic uppercase tracking-widest">
								Data Stream Empty
							</div>
						<% } %>
					</div>
					<a href="#" class="group w-full relative inline-flex items-center justify-center px-10 py-4 font-black text-white uppercase italic tracking-[0.2em] text-sm transition-all duration-300">
						<div class="absolute inset-0 border border-[#ffbd00]/30 skew-x-[-15deg] group-hover:border-[#ffbd00] transition-colors duration-300"></div>
						
						<div class="absolute inset-0 bg-[#ffbd00] skew-x-[-15deg] scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-right"></div>
						
						<div class="absolute -top-1 -left-1 w-2 h-2 border-t-2 border-l-2 border-[#ffbd00] group-hover:translate-x-1 group-hover:translate-y-1 transition-transform"></div>
						<div class="absolute -bottom-1 -right-1 w-2 h-2 border-b-2 border-r-2 border-[#ffbd00] group-hover:-translate-x-1 group-hover:-translate-y-1 transition-transform"></div>

						<div class="relative z-10 flex items-center gap-3 group-hover:text-black transition-colors duration-300">
							<span>View All Events</span>
							<svg class="w-5 h-5 transform group-hover:translate-x-2 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
							</svg>
						</div>
						<div class="absolute -inset-0.5 bg-[#ffbd00]/20 blur opacity-0 group-hover:opacity-100 transition-opacity duration-300 skew-x-[-15deg]"></div>
					</a>
				</div>
			</div>
		</div>
	</section>

	<section class="container px-4 mx-auto overflow-hidden">
	  <div class="relative z-10">
		<div class="flex flex-col lg:flex-row items-center lg:items-end justify-center lg:justify-between mb-6 gap-6">
		  <div class="flex items-center lg:items-end justify-center lg:justify-between">
			<div class="text-center lg:text-left">
			  <span class="text-[#ffbd00] text-xs font-black tracking-[0.4em] uppercase">Combat Intelligence</span>
			  <h2 class="text-4xl font-black italic uppercase tracking-tighter text-white">
				10 Best <span class="text-[#ffbd00]">Performance</span>
			  </h2>
			</div>
		  </div>
		  <div class="flex flex-col items-start md:items-end gap-2">
			<div class="flex gap-3">
			  <div class="px-3 py-1 bg-white/20 rounded border border-white/5 flex items-center gap-2">
				<div class="w-2 h-2 bg-green-500 rounded-full shadow-[0_0_5px_#22c55e]"></div>
				<span class="text-[10px] font-bold uppercase">Win Rate</span>
			  </div>
			  <div class="px-3 py-1 bg-white/20 rounded border border-white/5 flex items-center gap-2">
				<div class="w-2 h-2 bg-blue-500 rounded-full shadow-[0_0_5px_#3b82f6]"></div>
				<span class="text-[10px] font-bold uppercase">Pick</span>
			  </div>
			  <div class="px-3 py-1 bg-white/20 rounded border border-white/5 flex items-center gap-2">
				<div class="w-2 h-2 bg-rose-500 rounded-full shadow-[0_0_5px_#f43f5e]"></div>
				<span class="text-[10px] font-bold uppercase">Ban</span>
			  </div>
			</div>
		  </div>
		</div>
		<div class="relative group">
		  <div class="relative overflow-x-auto border bg-white/5 border-white/10 backdrop-blur-md shadow-2xl">
			<table class="w-full text-left border-collapse min-w-full">
			  <thead>
				<tr class="bg-white/5 border-b border-white/10">
				  <th class="px-8 py-5 text-[11px] font-black whitespace-nowrap uppercase tracking-[0.2em]">Hero Unit</th>
				  <th class="px-6 py-5 text-[11px] font-black whitespace-nowrap uppercase tracking-[0.2em] text-center w-52">Rank</th>
				  <th class="px-6 py-5 text-[11px] font-black whitespace-nowrap uppercase tracking-[0.2em] text-center w-52">Win Rate</th>
				  <th class="px-6 py-5 text-[11px] font-black whitespace-nowrap uppercase tracking-[0.2em] text-center w-52">Pick Rate</th>
				  <th class="px-6 py-5 text-[11px] font-black whitespace-nowrap uppercase tracking-[0.2em] text-center w-52">Ban Rate</th>
				</tr>
			  </thead>
				<tbody class="divide-y divide-white/10 relative">
				  <% allHeroes.slice(0, 10).forEach((hero, index) => { %>
					<tr class="group/row hover:bg-[#ffbd00]/[0.02] transition-all hover:z-50 relative border-t border-white/[0.05]">
					  <td class="px-6 py-3 w-full relative overflow-hidden group/row">
						  <a href="/heroes/<%= hero.hero_id %>" class="group/tooltip relative flex items-center gap-6 cursor-pointer focus:outline-none" tabindex="0">
							<div class="relative shrink-0">
							  <div class="relative w-16 h-16 p-0.5 bg-gradient-to-tr from-white/10 to-white/30 group-hover/row:from-[#ffbd00]/50 group-hover/row:to-[#ffee00]/50 transition-all duration-500 clip-path-gaming rounded">
								<div class="w-full h-full overflow-hidden bg-gray-900">
								  <img src="<%= hero.img_src %>" 
									   class="w-full h-full object-cover grayscale-[30%] group-hover/row:grayscale-0 group-hover/row:scale-110 transition-all duration-700">
								</div>
							  </div>

							  <div class="absolute -bottom-1 -right-2 bg-[#ffbd00] text-black px-1.5 py-0 skew-x-[-25deg] shadow-[0_0_15px_rgba(255,189,0,0.4)]">
								<span class="text-[11px] font-black italic block skew-x-[15deg]">
								  #<%= index + 1 %>
								</span>
							  </div>
							</div>

							<div class="relative z-10">
							  <div class="flex items-center gap-2">
								<div class="text-white font-black italic text-xl uppercase leading-none tracking-tighter group-hover/row:text-[#ffbd00] group-hover/row:translate-x-1 transition-all duration-300">
								  <%= hero.hero_name %>
								</div>
							  </div>
							  
							  <div class="flex items-center mt-2">
								<div class="bg-white/5 px-2 py-0.5 border-l-2 border-[#ffbd00] backdrop-blur-sm">
								  <div class="text-nowrap text-[9px] font-bold tracking-[0.2em] uppercase italic">
									<%= hero.role.join(' • ') %> <span class="mx-1 text-[#ffbd00]">/</span> <%= hero.lane.join(' • ') %>
								  </div>
								</div>
							  </div>
							  
							  <div class="mt-2 flex gap-1.5">
								<% hero.speciality.forEach(spec => { %>
								  <span class="text-[8px] px-1.5 py-0.5 border border-white/10 text-gray-300 uppercase font-bold group-hover/row:border-[#ffbd00]/30 transition-colors">
									<%= spec %>
								  </span>
								<% }) %>
							  </div>
							</div>
						  </div>
					  </td>
					  <td class="px-6 py-3">
						<div class="w-full max-w-[170px] mx-auto space-y-2">
						  <div class="flex justify-between items-end leading-none">
							<span class="text-sm font-black text-yellow-400 italic tabular-nums"><%= hero.stats.rank_name %></span>
						  </div>
						</div>
					  </td>
					  <td class="px-6 py-3">
						<div class="w-full max-w-[170px] mx-auto space-y-2">
						  <div class="flex justify-between items-end leading-none">
							<span class="text-sm font-black text-green-400 italic tabular-nums"><%= hero.stats.win_rate %>%</span>
						  </div>
						  <div class="h-1.5 w-full bg-black rounded-full border border-white/5 p-[1px]">
							<div class="h-full bg-gradient-to-r from-green-600 to-emerald-400 rounded-full shadow-[0_0_10px_rgba(16,185,129,0.3)]" 
								 style="width: <%= hero.stats.win_rate %>%"></div>
						  </div>
						</div>
					  </td>
					  <td class="px-6 py-3">
						<div class="w-full max-w-[170px] mx-auto space-y-2">
						  <div class="flex justify-between items-end leading-none">
							<span class="text-sm font-black text-blue-400 italic tabular-nums"><%= hero.stats.pick_rate %>%</span>
						  </div>
						  <div class="h-1.5 w-full bg-black rounded-full border border-white/5 p-[1px]">
							<div class="h-full bg-gradient-to-r from-blue-600 to-cyan-400 rounded-full shadow-[0_0_10px_rgba(37,99,235,0.3)]" 
								 style="width: <%= hero.stats.pick_rate %>%"></div>
						  </div>
						</div>
					  </td>
					  <td class="px-6 py-3">
						<div class="space-y-2">
						  <div class="flex justify-between items-end leading-none">
							<span class="text-sm font-black text-rose-500 italic tabular-nums"><%= hero.stats.ban_rate %>%</span>
						  </div>
						  <div class="h-1.5 w-full bg-black rounded-full border border-white/5 p-[1px]">
							<div class="h-full bg-gradient-to-r from-rose-700 to-red-500 rounded-full shadow-[0_0_10px_rgba(225,29,72,0.3)]" 
								 style="width: <%= hero.stats.ban_rate %>%"></div>
						  </div>
						</div>
					  </td>
					</tr>
				  <% }) %>
				  <div class="absolute bottom-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-[#ffbd00]/40 to-transparent scale-x-0 group-hover:scale-x-100 transition-transform duration-500"></div>
				</tbody>
			</table>
		  </div>
		</div>
		<div class="flex justify-center mt-6">
			<a href="#" class="group relative inline-flex items-center justify-center px-10 py-4 font-black text-white uppercase italic tracking-[0.2em] text-sm transition-all duration-300">
				<div class="absolute inset-0 border border-[#ffbd00]/30 skew-x-[-15deg] group-hover:border-[#ffbd00] transition-colors duration-300"></div>
				
				<div class="absolute inset-0 bg-[#ffbd00] skew-x-[-15deg] scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-right"></div>
				
				<div class="absolute -top-1 -left-1 w-2 h-2 border-t-2 border-l-2 border-[#ffbd00] group-hover:translate-x-1 group-hover:translate-y-1 transition-transform"></div>
				<div class="absolute -bottom-1 -right-1 w-2 h-2 border-b-2 border-r-2 border-[#ffbd00] group-hover:-translate-x-1 group-hover:-translate-y-1 transition-transform"></div>

				<div class="relative z-10 flex items-center gap-3 group-hover:text-black transition-colors duration-300">
					<span>All Statistycs</span>
					<svg class="w-5 h-5 transform group-hover:translate-x-2 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
					</svg>
				</div>
				<div class="absolute -inset-0.5 bg-[#ffbd00]/20 blur opacity-0 group-hover:opacity-100 transition-opacity duration-300 skew-x-[-15deg]"></div>
			</a>
		</div>
	  </div>
	</section>
	
	<section class="py-16 container px-4 mx-auto">
		<div class="flex justify-center lg:justify-start items-center gap-3 mb-2">
			<span class="text-[#ffbd00] text-xs font-black tracking-[0.4em] uppercase">Meta Rankings</span>
		</div>
		<% Object.keys(groupedHeroes).forEach(tier => { %>
		<div class="flex justify-center lg:items-end lg:justify-between mb-8">
			<div>
				<h2 class="text-4xl font-black italic uppercase tracking-tighter text-white">
					Tier <span class="text-[#ffbd00]"><%= tier %></span>
				</h2>
			</div>
			<div class="hidden lg:flex h-[1px] flex-1 bg-gradient-to-r from-[#ffbd00]/50 to-transparent ml-8 mb-3 opacity-30"></div>
		</div>
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-4 gap-6 mb-6">
			<% groupedHeroes[tier].forEach(hero => { %>
			<a href="/heroes/<%= hero.hero_id %>" class="group relative bg-white/5 border border-white/10 p-4 transition-all duration-500 hover:border-[#ffbd00]/20 hover:-translate-y-2 overflow-hidden cursor-pointer" tabindex="0">
				<div class="absolute -top-12 -right-12 w-32 h-32 bg-[#ffbd00]/10 blur-[40px] group-hover:bg-[#ffbd00]/20 transition-all duration-700"></div>
					<% 
					const tierStyles = {
						SS: "from-rose-600 to-orange-500 shadow-rose-900/50 text-white",
						S:  "from-amber-400 to-yellow-600 shadow-yellow-900/50 text-black",
						A:  "from-purple-500 to-indigo-600 shadow-indigo-900/50 text-white",
						B:  "from-blue-500 to-cyan-500 shadow-blue-900/50 text-white",
						C:  "from-emerald-500 to-teal-600 shadow-emerald-900/50 text-white",
						D:  "from-slate-500 to-slate-700 shadow-slate-900/50 text-white"
					};
					const currentStyle = tierStyles[hero.tier] || "from-gray-600 to-gray-800 text-white shadow-gray-900/50";
					%>
				<div class="absolute top-4 right-4 z-20">
					<div class="bg-gradient-to-br <%= currentStyle %> text-[10px] font-black px-2 py-0.5 rounded shadow-lg skew-x-[-10deg] border border-white/20 uppercase">
						<%= hero.tier %>
					</div>
				</div>
				<div class="relative z-10 flex flex-col gap-2">
					<div class="flex items-center gap-4">
						<div class="relative shrink-0">
							<div class="absolute inset-0 bg-[#ffbd00] rounded-full blur-md opacity-0 group-hover:opacity-40 transition-opacity"></div>
							<div class="w-16 h-16 rounded-full overflow-hidden border-2 border-white/10 group-hover:border-[#ffbd00]/20 transition-all duration-500 relative z-10">
								<img src="<%= hero.img_src %>" alt="<%= hero.hero_name %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
							</div>
						</div>
						<div class="overflow-hidden">
							<h4 class="text-white font-black italic uppercase tracking-wider text-lg leading-tight truncate group-hover:text-[#ffbd00] transition-colors">
								<%= hero.hero_name %>
							</h4>
							<p class="text-[10px] font-bold uppercase tracking-widest mt-1 truncate">
								<%= hero.role.join(' / ') %>
							</p>
						</div>
					</div>
					<div class="grid grid-cols-2 gap-2 pt-2 border-t border-white/5">
						<div class="flex flex-col">
							<span class="block text-[8px] text-gray-300 uppercase font-bold tracking-widest">Main Lane</span>
							<span class="text-[11px] font-black italic uppercase"><%= hero.lane[0] %></span>
						</div>
						<div class="text-right flex flex-col">
							<span class="block text-[8px] text-gray-300 uppercase font-bold tracking-widest">Power Score</span>
							<span class="text-[11px] text-[#ffbd00] font-black italic"><%= hero.score.toLocaleString() %></span>
						</div>
					</div>
					<div class="flex gap-1.5">
						<% hero.speciality.slice(0, 2).forEach(spec => { %>
							<span class="px-2 py-0.5 bg-white/5 border border-white/10 text-[8px] font-bold uppercase tracking-tighter">
								<%= spec %>
							</span>
						<% }) %>
					</div>
				</div>
				<div class="absolute bottom-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-[#ffbd00]/40 to-transparent scale-x-0 group-hover:scale-x-100 transition-transform duration-500"></div>
			</a>
			<% }) %>
		</div>
		<% }) %>
		<div class="flex justify-center">
			<a href="/tiers" class="group relative inline-flex items-center justify-center px-10 py-4 font-black text-white uppercase italic tracking-[0.2em] text-sm transition-all duration-300">
				<div class="absolute inset-0 border border-[#ffbd00]/30 skew-x-[-15deg] group-hover:border-[#ffbd00] transition-colors duration-300"></div>
				
				<div class="absolute inset-0 bg-[#ffbd00] skew-x-[-15deg] scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-right"></div>
				
				<div class="absolute -top-1 -left-1 w-2 h-2 border-t-2 border-l-2 border-[#ffbd00] group-hover:translate-x-1 group-hover:translate-y-1 transition-transform"></div>
				<div class="absolute -bottom-1 -right-1 w-2 h-2 border-b-2 border-r-2 border-[#ffbd00] group-hover:-translate-x-1 group-hover:-translate-y-1 transition-transform"></div>

				<div class="relative z-10 flex items-center gap-3 group-hover:text-black transition-colors duration-300">
					<span>Explore All Tiers</span>
					<svg class="w-5 h-5 transform group-hover:translate-x-2 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
					</svg>
				</div>
				<div class="absolute -inset-0.5 bg-[#ffbd00]/20 blur opacity-0 group-hover:opacity-100 transition-opacity duration-300 skew-x-[-15deg]"></div>
			</a>
		</div>
	</section>
</article>