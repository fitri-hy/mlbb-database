<article class="h-full flex-1 px-4 pt-26 pb-6 relative overflow-hidden">
  <img class="fixed top-0 left-0 w-full h-full max-h-[700px] object-cover opacity-80 -z-10 trans-bottom" src="/assets/images/banner.webp" alt="banner" />

    <section class="container mx-auto relative z-10">
		<div class="mb-10 flex flex-col md:flex-row md:justify-between items-center gap-6">
			<div class="pl-4 border-l-4 border-[#ffbd00]">
				<h1 class="text-3xl md:text-5xl font-black text-white italic uppercase tracking-tighter">
					Emblem <span class="text-[#ffbd00]">Matrix</span>
				</h1>
				<p class="text-[10px] font-bold tracking-[0.3em] uppercase mt-1">Tactical Enhancement</p>
			</div>
        </div>
		
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-6">
            <% if (allEmblems.length > 0) { %>
                <% allEmblems.forEach(emblem => { %>
                    <div class="group relative bg-white/10 border border-white/10 backdrop-blur-md p-5 transition-all duration-500 hover:border-[#ffbd00]/50 hover:bg-[#ffbd00]/[0.02] clip-path-gaming flex flex-col gap-4">
                        
                        <div class="flex items-center gap-4">
                            <div class="relative shrink-0">
                                <div class="w-16 h-16 bg-gray-900 border border-white/10 overflow-hidden relative group-hover:border-[#ffbd00]/50 transition-colors">
                                    <img src="https://mlbb.io/images/emblem/main/<%= emblem.img_src %>" alt="<%= emblem.name %>" class="w-full h-full object-contain p-2 group-hover:scale-110 transition-all duration-700">
                                </div>
                            </div>
                            <div class="flex-1">
                                <h3 class="text-white font-black italic uppercase text-lg md:text-2xl tracking-tighter group-hover:text-[#ffbd00] transition-colors leading-none">
                                    <%= emblem.name %>
                                </h3>
                                <p class="text-[9px] font-bold uppercase tracking-widest mt-1">Base Enhancement</p>
                            </div>
                        </div>

                        <div class="pt-4 border-t border-white/5 flex flex-col gap-3">
                            <div class="flex items-center gap-2">
                                <div class="w-1 h-3 bg-[#ffbd00]"></div>
                                <span class="text-[9px] font-bold uppercase tracking-widest text-[#ffbd00]">
                                    Technical Statistics
                                </span>
                            </div>
                            
                            <div class="grid gap-2">
                                <% emblem.attributes.forEach(attr => { %>
                                    <div class="flex justify-between items-center bg-white/5 px-3 py-2 border-l-2 border-[#ffbd00]/30 group-hover:border-[#ffbd00] transition-colors">
                                        <% 
                                            let parts = attr.split(/(?=[+-])/); 
                                            let label = parts[0];
                                            let value = parts[1] || "";
                                        %>
                                        <span class="text-[10px] font-bold uppercase text-gray-300 truncate mr-2"><%= label.trim() %></span>
                                        <span class="text-xs font-black text-emerald-400 font-mono"><%= value.trim() %></span>
                                    </div>
                                <% }) %>
                            </div>
                        </div>

                        <div class="absolute -bottom-1 -right-1 w-4 h-4 border-b border-r border-white/20 group-hover:border-[#ffbd00] transition-colors"></div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-span-full py-20 text-center border border-dashed border-white/10 rounded-lg">
                    <p class="text-gray-600 font-black italic uppercase tracking-[0.4em]">Emblem Data Not Synchronized</p>
                </div>
            <% } %>
        </div>
    </section>
</article>