<article class="h-full flex-1 px-4 pt-26 pb-6 relative overflow-hidden">
  <img class="fixed top-0 left-0 w-full h-full max-h-[700px] object-cover opacity-80 -z-10 trans-bottom" src="/assets/images/banner.webp" alt="banner" />

    <section class="container mx-auto relative z-10">
		<div class="mb-10 flex flex-col md:flex-row md:justify-between items-center gap-6">
			<div class="pl-4 border-l-4 border-[#ffbd00]">
				<h1 class="text-3xl md:text-5xl font-black text-white italic uppercase tracking-tighter">
					Tournament <span class="text-[#ffbd00]">History</span>
				</h1>
				<p class="text-[10px] font-bold tracking-[0.3em] uppercase mt-1">Combat Archives</p>
			</div>
        </div>

      <div class="grid grid-cols-1 md:grid-cols-2 2xl:grid-cols-3 gap-5">
        <% data.forEach(tournament => { %>
          <a href="/tournaments/<%= tournament.id %>" class="group relative bg-white/10 border border-white/10 backdrop-blur-md p-4 transition-all duration-500 hover:border-[#ffbd00]/50 hover:bg-[#ffbd00]/[0.02] clip-path-gaming cursor-pointer">
            <div class="flex flex-col gap-4">
              <div class="flex items-center gap-4">
                <div class="flex-1 overflow-hidden mt-1">
                  <h3 class="text-white font-black italic uppercase text-lg truncate tracking-tighter group-hover:text-[#ffbd00] transition-colors leading-none">
                    <%= tournament.name %>
                  </h3>
				  <div class="mt-1 pt-3 flex flex-col gap-2">
					<div class="flex items-center gap-2">
					  <div class="w-1 h-3 bg-[#ffbd00]"></div>
					  <span class="text-[9px] font-bold uppercase tracking-widest text-gray-300">
						Event Period
					  </span>
					</div>
					<div class="flex flex-wrap gap-1.5">
					  <span class="text-[8px] px-2 py-0.5 bg-white/10 border border-white/5 font-mono uppercase group-hover:text-[#ffbd00] transition-colors">
						<%= tournament.date %>
					  </span>
					  <span class="text-[8px] px-2 py-0.5 bg-white/10 border border-white/5 font-mono uppercase group-hover:text-[#ffbd00] transition-colors">
						ID: #<%= tournament.id %>
					  </span>
					</div>
				  </div>
                </div>
              </div>
            </div>

            <div class="absolute -bottom-1 -right-1 w-4 h-4 border-b border-r border-white/20 group-hover:border-[#ffbd00] transition-colors"></div>
          </a>
        <% }) %>
      </div>
    </div>
  </section>
</article>