<article class="h-full flex-1 px-4 pt-26 pb-6 relative overflow-hidden">
  <img class="fixed top-0 left-0 w-full h-full max-h-[700px] object-cover opacity-80 -z-10 trans-bottom" src="/assets/images/banner.webp" alt="banner" />

    <section class="container mx-auto relative z-10">
		<div class="mb-10 flex flex-col md:flex-row md:justify-between items-center gap-6">
			<div class="pl-4 border-l-4 border-[#ffbd00]">
				<h1 class="text-3xl md:text-5xl font-black text-white italic uppercase tracking-tighter">
					<%= tournament.name %> <span class="text-[#ffbd00]">Stats</span>
				</h1>
				<p class="text-[10px] font-bold tracking-[0.3em] uppercase mt-1">#<%= tournament.id %> • <%= new Date(lastUpdated).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }).toUpperCase() %></p>
			</div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-12">
            <% 
              const summaryTypes = [
                { label: 'Most Contested', data: summary.most_contested[0], color: '#ffbd00', statLabel: 'Presence', cornerHover: 'group-hover:border-[#ffbd00]' },
                { label: 'Most Successful', data: summary.most_successful[0], color: '#22c55e', statLabel: 'Win Rate', cornerHover: 'group-hover:border-green-500' },
                { label: 'Overrated', data: summary.overrated[0], color: '#ef4444', statLabel: 'Win Rate', cornerHover: 'group-hover:border-red-500' }
              ]
              summaryTypes.forEach(type => { 
            %>
            <a href="/heroes/<%= type.data.hero_id %>" class="group relative bg-white/10 backdrop-blur-sm border border-white/10 p-5 transition-all duration-300 hover:border-[#ffbd00]/50 hover:bg-white/10 overflow-hidden">
                <div class="absolute inset-y-0 left-0 w-1 bg-[#ffbd00] transform -translate-x-full group-hover:translate-x-0 transition-transform"></div>
                
                <div class="absolute top-0 right-0 z-20">
                    <div style="background-color: <%= type.color %>" class="text-black px-3 py-1 -mr-1 -mt-1 skew-x-[-15deg] shadow-lg">
                        <p class="text-[9px] font-black leading-none italic uppercase"><%= type.label %></p>
                    </div>
                </div>
                
                <div class="flex items-center gap-4">
                    <div class="w-16 h-16 bg-gray-900 border border-white/10 overflow-hidden relative group-hover:border-[#ffbd00]/50 transition-colors">
                        <img src="<%= type.data.img_src %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                    </div>
                    <div>
                        <h4 class="text-white font-black italic uppercase text-xl truncate tracking-tighter leading-none mb-2 group-hover:text-[#ffbd00] transition-colors"><%= type.data.hero_name %></h4>
                        <div class="flex items-center gap-2">
                            <div style="background-color: <%= type.color %>" class="w-1 h-3"></div>
                            <span class="text-[10px] font-bold uppercase tracking-widest">
                                <%= type.statLabel %>: <span class="text-white font-mono"><%= type.data.pick_ban_rate || type.data.win_rate %>%</span>
                            </span>
                        </div>
                    </div>
                </div>

                <div class="absolute -bottom-1 -right-1 w-4 h-4 border-b border-r border-white/20 <%= type.cornerHover %> transition-colors"></div>
                <div class="absolute bottom-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-[#ffbd00]/40 to-transparent scale-x-0 group-hover:scale-x-100 transition-transform duration-500"></div>
            </a>
            <% }) %>
        </div>

        <div class="group relative">
			<div class="relative overflow-x-auto border bg-white/10 border-white/10 backdrop-blur-md shadow-2xl">
				<div class="absolute bottom-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-[#ffbd00]/40 to-transparent scale-x-0 group-hover:scale-x-100 transition-transform duration-500"></div>
		  
					<table class="w-full text-left border-collapse min-w-full">
                        <thead>
							<tr class="bg-white/10 border-b border-white/10">
                                <th class="px-8 py-5 text-[11px] font-black whitespace-nowrap uppercase tracking-[0.2em]">Unit Identifier</th>
                                <th class="px-8 py-5 text-[11px] font-black whitespace-nowrap uppercase tracking-[0.2em]">Engagement</th>
                                <th class="px-8 py-5 text-[11px] font-black whitespace-nowrap uppercase tracking-[0.2em]">Win Efficiency</th>
                                <th class="px-8 py-5 text-[11px] font-black whitespace-nowrap uppercase tracking-[0.2em]">Total Presence</th>
                            </tr>
                        </thead>
						<tbody class="divide-y divide-white/10 relative">
                            <% stats.forEach((hero, index) => { %>
								<tr class="group/row hover:bg-[#ffbd00]/[0.02] transition-all hover:z-50 relative border-t border-white/[0.05]">
									<td class="px-6 py-3 w-full relative overflow-hidden group/row">
                                        <a href="/heroes/<%= hero.hero_id %>" class="flex items-center gap-5">
                                            <div class="relative w-14 h-14 p-0.5 bg-white/10 group-hover/row:bg-[#ffbd00]/50 transition-all duration-500 clip-path-gaming">
                                                <div class="w-full h-full overflow-hidden bg-gray-900">
                                                    <img src="<%= hero.img_src %>" class="w-full h-full object-cover group-hover/row:scale-110 transition-transform duration-700">
                                                </div>
                                            </div>
                                            <div>
                                                <div class="text-white font-black italic text-lg uppercase tracking-tighter group-hover/row:text-[#ffbd00] transition-colors leading-none">
                                                    <%= hero.hero_name %>
                                                </div>
                                                <div class="text-[9px] font-bold uppercase mt-1 tracking-widest"><%= hero.role.join(' • ') %></div>
                                            </div>
                                        </a>
                                    </td>
                                    <td class="px-6 py-4 font-bold text-center font-mono text-white text-xs">
                                        <span class="text-sky-400"><%= hero.total_picks %>P</span> / <span class="text-rose-500"><%= hero.total_bans %>B</span>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="w-full max-w-[130px] mx-auto space-y-1">
                                            <div class="flex justify-between text-[10px] font-black font-mono leading-none">
                                                <span class="text-green-400 italic"><%= hero.win_rate %>%</span>
                                            </div>
                                            <div class="h-1 w-full bg-white/10 rounded-full overflow-hidden">
                                                <div class="h-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.4)]" style="width: <%= hero.win_rate %>%"></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-center">
                                        <span class="inline-block bg-white/10 border border-white/10 px-3 py-1 font-mono text-[#ffbd00] text-sm italic skew-x-[-15deg] group-hover/row:border-[#ffbd00]/50 transition-colors">
                                            <span class="block skew-x-[15deg]"><%= hero.pick_ban_rate %>%</span>
                                        </span>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>
</article>