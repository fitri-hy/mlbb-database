<article class="h-full flex-1 px-4 pt-26 pb-6 relative overflow-hidden">
  <img class="fixed top-0 left-0 w-full h-full max-h-[700px] object-cover opacity-80 -z-10 trans-bottom" src="/assets/images/banner.webp" alt="banner" />

  <section class="relative z-10 container mx-auto">
    <div class="mb-10 flex flex-col md:flex-row md:justify-between items-center gap-6">
      <div class="pl-4 border-l-4 border-[#ffbd00]">
        <h1 class="text-3xl md:text-5xl font-black text-white italic uppercase tracking-tighter">
          Hero <span class="text-[#ffbd00]">Tiers</span>
        </h1>
        <p class="text-[10px] font-bold tracking-[0.3em] uppercase mt-1">Meta Ranking</p>
      </div>
      <div class="max-w-xs w-full">
        <form action="/tiers" method="GET" class="relative group">
          <div class="absolute -inset-0.5 bg-gradient-to-r from-[#ffbd00]/30 to-orange-600/30 rounded-sm blur opacity-20 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
          <div class="relative flex">
            <div class="absolute z-10 top-0 left-0 w-2 h-2 border-t-2 border-l-2 border-[#ffbd00]"></div>
            <input 
              type="text" 
              name="search" 
              placeholder="SEARCH HERO NAME..." 
              value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
              class="placeholder:text-gray-200 w-full bg-white/20 backdrop-blur-md border border-white/10 px-5 py-4 text-white text-[10px] font-black tracking-[0.2em] uppercase focus:outline-none focus:border-[#ffbd00]/50 transition-all italic"
            />
            <button type="submit" class="cursor-pointer bg-[#ffbd00]/90 px-4 text-black group-hover:bg-[#ffbd00] transition-all transform group-hover:scale-110">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </button>
          </div>
        </form>
      </div>
    </div>

    <% if (locals.sortedTiers && sortedTiers.length > 0) { %>
      <% sortedTiers.forEach(tier => { 
        const tierStyles = {
            SS: "from-rose-600 to-orange-500 shadow-rose-900/50 text-white",
            S:  "from-amber-400 to-yellow-600 shadow-yellow-900/50 text-white",
            A:  "from-purple-500 to-indigo-600 shadow-indigo-900/50 text-white",
            B:  "from-blue-500 to-cyan-500 shadow-blue-900/50 text-white",
            C:  "from-emerald-500 to-teal-600 shadow-emerald-900/50 text-white",
            D:  "from-slate-500 to-slate-700 shadow-slate-900/50 text-white"
        };
        const currentStyle = tierStyles[tier] || "from-gray-600 to-gray-800 text-white shadow-gray-900/50";
      %>

        <div class="mt-6 mb-8 flex justify-between items-center gap-6">
          <div class="relative">
            <div class="absolute inset-0 bg-gradient-to-r <%= currentStyle %> blur-md opacity-20"></div>
            <div class="relative bg-gradient-to-r <%= currentStyle %> px-4 py-2 md:px-8 md:py-2 skew-x-[-15deg] font-black italic text-lg md:text-3xl shadow-lg">
              TIER <%= tier %>
            </div>
          </div>
          
          <div class="hidden md:flex h-[1px] flex-1 bg-gradient-to-r <%= currentStyle.split(' ')[0] %> via-white/10 to-transparent opacity-40"></div>
          
          <span class="text-[10px] font-mono uppercase tracking-[0.3em] text-gray-400">
            <%= groupedHeroes[tier].length %> Heroes Detected
          </span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 md:grid-cols-4 2xl:grid-cols-5 gap-4">
          <% groupedHeroes[tier].forEach(function(hero) { %>
            <a href="/heroes/<%= hero.hero_id %>" class="group relative bg-white/10 border border-white/10 backdrop-blur-md p-2 transition-all duration-500 hover:border-white/30 hover:bg-white/[0.05] clip-path-gaming">
              
              <div class="absolute top-4 right-4 z-20">
                <div class="bg-gradient-to-br <%= currentStyle %> text-[10px] font-black px-2 py-0.5 rounded shadow-lg skew-x-[-10deg] border border-white/20 uppercase">
                  <%= hero.tier %>
                </div>
              </div>

              <div class="flex items-center gap-3">
                <div class="relative shrink-0">
                  <div class="w-20 h-20 bg-gray-900 border border-white/10 overflow-hidden relative group-hover:border-white/40 transition-colors">
                    <img src="<%= hero.img_src %>" alt="<%= hero.hero_name %>" class="w-full h-full object-cover group-hover:scale-110 transition-all duration-700">
                  </div>
                </div>

                <div class="flex-1 overflow-hidden">
					<% 
					  const tierHoverTexts = {
						  SS: "group-hover:text-rose-500",
						  S:  "group-hover:text-amber-400",
						  A:  "group-hover:text-purple-400",
						  B:  "group-hover:text-blue-400",
						  C:  "group-hover:text-emerald-400",
						  D:  "group-hover:text-slate-400"
					  };
					  const currentHoverText = tierHoverTexts[tier] || "group-hover:text-[#ffbd00]";
					%>
				  <h3 class="text-white font-black italic uppercase text-xl truncate tracking-tighter <%= currentHoverText %> transition-colors duration-300 leading-none">
					<%= hero.hero_name %>
                  </h3>
                  <div class="flex flex-wrap gap-x-2 mt-1">
                    <% if (Array.isArray(hero.role)) { %>
                      <% hero.role.forEach(r => { %>
                        <span class="text-[9px] font-bold uppercase tracking-widest text-gray-400 group-hover:text-white transition-colors">
                          <%= r %>
                        </span>
                      <% }) %>
                    <% } %>
                  </div>
                </div>
              </div>

              <div class="grid grid-cols-2 gap-2 pt-2 border-t border-white/5 mt-2">
                <div class="flex flex-col">
                  <span class="block text-[8px] text-gray-400 uppercase font-bold tracking-widest">Main Lane</span>
                  <span class="text-[11px] font-black italic uppercase text-white">
                    <%= Array.isArray(hero.lane) ? hero.lane[0] : hero.lane %>
                  </span>
                </div>
                <div class="text-right flex flex-col">
                  <span class="block text-[8px] text-gray-400 uppercase font-bold tracking-widest">Power Score</span>
                  <span class="text-[11px] font-black italic bg-gradient-to-r <%= currentStyle %> bg-clip-text text-transparent brightness-150">
                    <%= hero.score.toLocaleString() %>
                  </span>
                </div>
              </div>

              <div class="flex gap-1.5 mt-2">
                <% if (hero.speciality) { %>
                  <% hero.speciality.slice(0, 2).forEach(spec => { %>
                    <span class="px-2 py-0.5 bg-white/5 border border-white/10 text-[8px] font-bold uppercase tracking-tighter text-gray-300">
                      <%= spec %>
                    </span>
                  <% }) %>
                <% } %>
              </div>

              <div class="absolute top-0 left-0 w-2 h-2 border-t border-l border-white/20"></div>
              <div class="absolute bottom-0 right-0 w-4 h-4 border-b border-r border-white/20 group-hover:border-white/50 transition-colors"></div>
            </a>
          <% }); %>
        </div>
      <% }); %>
    <% } else { %>
      <div class="flex flex-col items-center justify-center py-40 border-2 border-dashed border-white/10 rounded-3xl bg-black/40">
        <div class="w-16 h-16 border-4 border-[#ffbd00]/20 border-t-[#ffbd00] rounded-full animate-spin mb-6"></div>
        <h2 class="text-white uppercase font-black italic tracking-[0.5em] text-xl">System: No Data Found</h2>
        <p class="text-gray-500 text-xs mt-2 uppercase tracking-widest">Please check your database or search criteria</p>
        <a href="/tiers" class="mt-8 px-6 py-2 border border-[#ffbd00] text-[#ffbd00] text-[10px] font-bold uppercase hover:bg-[#ffbd00] hover:text-black transition-all">Reset Database View</a>
      </div>
    <% } %>
  </section>
</article>