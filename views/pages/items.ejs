<article class="h-full flex-1 px-4 pt-26 pb-6 relative overflow-hidden">
  <img class="fixed top-0 left-0 w-full h-full max-h-[700px] object-cover opacity-80 -z-10 trans-bottom" src="/assets/images/banner.webp" alt="banner" />

    <section class="container mx-auto relative z-10">
		<div class="mb-10 flex flex-col md:flex-row md:justify-between items-center gap-6">
			<div class="pl-4 border-l-4 border-[#ffbd00]">
				<h1 class="text-3xl md:text-5xl font-black text-white italic uppercase tracking-tighter">
					Items <span class="text-[#ffbd00]">Matrix</span>
				</h1>
				<p class="text-[10px] font-bold tracking-[0.3em] uppercase mt-1">Armory Enhancement</p>
			</div>
        </div>

	<div class="flex overflow-x-auto no-scrollbar justify-start md:justify-start gap-2 mb-6 pb-2 px-1 md:mx-0 md:px-0 scroll-smooth">
	  <% categories.forEach((cat, index) => { %>
		<button 
		  onclick="switchTab('<%= cat %>')" 
		  id="tab-btn-<%= cat %>"
		  class="tab-button whitespace-nowrap shrink-0 px-6 py-2 md:px-8 md:py-3 bg-white/10 backdrop-blur-md border border-white/10 text-[9px] md:text-[10px] font-black uppercase tracking-[0.2em] italic transition-all duration-300 hover:bg-[#ffbd00]/10 hover:border-[#ffbd00]/50 <%= index === 0 ? 'active-tab' : '' %>"
		>
		  <%= cat %>
		</button>
	  <% }) %>
	</div>

    <% Object.keys(groupedItems).forEach((category, index) => { %>
      <div 
        id="content-<%= category %>" 
        class="tab-content transition-all duration-500 <%= index === 0 ? 'block animate-fade-in' : 'hidden' %>"
      >
        <div class="grid grid-cols-1 md:grid-cols-3 md:grid-cols-4 xl:grid-cols-5 gap-4">
          <% groupedItems[category].forEach(item => { %>
			<div class="group relative bg-white/10 border border-white/10 backdrop-blur-md p-5 transition-all duration-500 hover:border-[#ffbd00]/50 hover:bg-[#ffbd00]/[0.02] clip-path-gaming flex flex-col gap-4">
              
              <div class="absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-white/5 to-transparent"></div>

              <div class="absolute top-0 right-0 z-20">
                <div class="bg-[#ffbd00] text-black px-3 py-1 -mr-1 -mt-1 skew-x-[-15deg] font-black italic text-[11px] shadow-[0_0_10px_rgba(255,189,0,0.3)]">
                  $<%= item.price_total %>
                </div>
              </div>

              <div class="flex items-center gap-2">
                <div class="relative shrink-0">
                  <div class="w-16 h-16 bg-gray-900 border-2 border-white/5 p-1 group-hover:border-[#ffbd00]/60 transition-all duration-500 overflow-hidden">
                    <img src="https://mlbb.io<%= item.image_path %>" alt="<%= item.name %>" class="w-full h-full object-contain group-hover:scale-110 transition-transform">
                  </div>
                </div>

                <div class="flex-1 min-w-0">
                  <h4 class="text-white font-black italic uppercase text-lg truncate group-hover:transition-colors tracking-tighter">
                    <%= item.display_name %>
                  </h4>
                </div>
              </div>

              <div class="border-t pt-4 border-white/10 h-full min-h-[50px] max-h-[60px] overflow-hidden group/desc">
                <div class="h-full overflow-y-auto pr-1 custom-scrollbar">
                  <p class="text-[10px] italic leading-[1.4] <%= item.passive_description ? 'text-gray-100' : 'text-gray-200 uppercase font-bold tracking-tighter' %>">
                    <% if(item.passive_name) { %>
                      <span class="font-black not-italic uppercase text-[9px] mr-1 inline-block border-b border-[#ffbd00]/30">
                        <%= item.passive_name %>:
                      </span>
                    <% } %>
                    <%= item.passive_description || "N/A" %>
                  </p>
                </div>
              </div>

              <div class="grid grid-cols-3 gap-2">
                <% if(item.hp > 0) { %>
                  <div class="bg-black/30 p-1 border-l-2 border-emerald-500">
                    <span class="block text-[7px] text-gray-500 uppercase font-black tracking-tighter">HP</span>
                    <span class="text-[11px] font-black text-emerald-400">+<%= item.hp %></span>
                  </div>
                <% } %>
                <% if(item.physical_attack > 0) { %>
                  <div class="bg-black/30 p-1 border-l-2 border-red-500">
                    <span class="block text-[7px] text-gray-500 uppercase font-black tracking-tighter">Phys ATK</span>
                    <span class="text-[11px] font-black text-red-400">+<%= item.physical_attack %></span>
                  </div>
                <% } %>
                <% if(item.magic_power > 0) { %>
                  <div class="bg-black/30 p-1 border-l-2 border-blue-500">
                    <span class="block text-[7px] text-gray-500 uppercase font-black tracking-tighter">Magic PWR</span>
                    <span class="text-[11px] font-black text-blue-400">+<%= item.magic_power %></span>
                  </div>
                <% } %>
              </div>

              <div class="absolute -bottom-1 -right-1 w-4 h-4 border-b-2 border-r-2 border-white/10 group-hover:border-[#ffbd00] transition-colors"></div>
            </div>
          <% }) %>
        </div>
      </div>
    <% }) %>
  </section>
</article>